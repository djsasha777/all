{% if tlsEnabled %}
{
    "server": ["127.0.0.1"],
    "mode": "tcp",
    "server_port": 14801,
    "local_port": 2081,
    "password": "{{ sspassword }}",
    "timeout": 86400,
    "method": "aes-256-gcm",
    "plugin": "obfs-server",
    "plugin_opts": "obfs=tls;obfs-host=shadow.spongo.ru;cert=/etc/shadowsocks-libev/server.crt;key=/etc/shadowsocks-libev/server.key"
}
{% else %}
{
    "server":["0.0.0.0"],
    "mode":"tcp",
    "server_port":14800,
    "local_port":2080,
    "password": "{{ sspassword }}",
    "timeout":86400,
    "method":"aes-256-gcm"
}
{% endif %}